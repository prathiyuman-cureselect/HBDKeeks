;animation-duration:15s;animation-delay:4.4s}@keyframes floatUp{0%{transform:translateY(0) translateX(0) rotate(-4deg);opacity:0}10%{opacity:.92}50%{transform:translateY(-55vh) translateX(16px) rotate(3deg)}90%{opacity:.8}100%{transform:translateY(-118vh) translateX(-12px) rotate(-3deg);opacity:0}}.splash-content{position:relative;z-index:2;padding:0 24px}.splash-title{font-family:'Cormorant Garamond',serif;font-weight:600;line-height:1.05;display:flex;flex-direction:column;align-items:center;gap:2px}.splash-title .word{opacity:0;font-size:clamp(40px,11vw,78px);background:linear-gradient(135deg,var(--gold-bright),var(--gold) 55%,var(--rose));-webkit-background-clip:text;background-clip:text;color:transparent;filter:drop-shadow(0 0 18px rgba(201,163,95,.35));animation:.9s cubic-bezier(.22,1,.36,1) forwards wordRise}.splash-title .happy{animation-delay:.25s}.splash-title .birthday{animation-delay:.6s}@keyframes wordRise{from{opacity:0;transform:translateY(26px) scale(.9)}to{opacity:1;transform:translateY(0) scale(1)}}.splash-name{margin-top:16px;font-family:'Petit Formal Script',cursive;font-size:clamp(28px,6.5vw,42px);color:var(--cream);opacity:0;animation:.9s cubic-bezier(.22,1,.36,1) 1.05s forwards wordRise}.splash-name .sparkle{color:var(--gold-bright);font-family:Inter,sans-serif;display:inline-block;animation:1.6s infinite sparkleTwinkle}@keyframes sparkleTwinkle{0%,100%{opacity:.4;transform:scale(.9)}50%{opacity:1;transform:scale(1.15)}}.splash-sub{margin-top:14px;font-family:Inter,sans-serif;font-size:clamp(12px,2.2vw,13.5px);letter-spacing:1.5px;color:var(--cream-dim);opacity:0;animation:.9s cubic-bezier(.22,1,.36,1) 1.25s forwards wordRise}.splash-btn{margin-top:34px;opacity:0;animation:.9s cubic-bezier(.22,1,.36,1) 1.45s forwards wordRise,2.2s 2.4s infinite btnPulse}@keyframes btnPulse{0%,100%{box-shadow:0 10px 24px rgba(201,163,95,.25)}50%{box-shadow:0 10px 30px rgba(201,163,95,.5)}}@media (max-height:480px){.splash-title .word{font-size:clamp(30px,8vw,52px)}.splash-name{font-size:clamp(22px,5vw,30px);margin-top:10px}.splash-btn{margin-top:20px}}.gate-screen{position:absolute;inset:0;display:none;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:24px;z-index:200}.gate-screen.active{display:flex;animation:.95s cubic-bezier(.19,1,.22,1) screenIn}.gate-icon{width:38px;height:38px;margin:0 auto 16px;opacity:.9;animation:3.6s ease-in-out infinite breathe}.gate-icon svg{width:100%;height:100%}.countdown-grid{display:flex;gap:clamp(10px,3vw,18px);justify-content:center;margin:8px 0 26px;flex-wrap:nowrap}.cd-tile{background:rgba(244,236,221,.03);border:1px solid var(--gold-dim);border-radius:6px;padding:clamp(14px,3vw,22px) clamp(10px,2.6vw,20px);min-width:clamp(58px,15vw,86px);transition:border-color .3s,box-shadow .3s}.cd-tile.pulse{border-color:var(--gold);box-shadow:0 0 18px rgba(201,163,95,.28)}.cd-num{display:block;font-family:'Cormorant Garamond',serif;font-size:clamp(26px,7vw,42px);color:var(--gold-bright);font-weight:600;line-height:1;font-variant-numeric:tabular-nums;text-shadow:0 0 16px rgba(201,163,95,.3)}.cd-label{display:block;margin-top:8px;font-size:clamp(9px,1.8vw,10.5px);letter-spacing:2px;text-transform:uppercase;color:var(--cream-dim)}.cd-sep{display:flex;align-items:center;font-family:'Cormorant Garamond',serif;font-size:clamp(22px,5vw,32px);color:var(--gold-dim);padding-bottom:18px}#cdBtnRow{display:none}@media (max-height:480px){.countdown-grid{margin:6px 0 16px}.cd-tile{padding:10px}}@media (max-width:340px){.countdown-grid{gap:6px}.cd-tile{min-width:50px;padding:10px 6px}}::selection{background:var(--gold);color:#171123}img{-webkit-user-drag:none;user-drag:none;pointer-events:none}.devtools-blur{filter:blur(24px) brightness(.3)!important;transition:filter .2s}.devtools-warning{position:fixed;inset:0;z-index:99999;display:none;align-items:center;justify-content:center;text-align:center;background:rgba(10,7,15,.96);color:var(--gold-bright);font-family:'Cormorant Garamond',serif;font-size:clamp(16px,3vw,22px);padding:32px}.devtools-warning.show{display:flex}</style></head><body data-wm="a2Vla3MtYmlydGhkYXktMjAyNi0wNy0wOC1kby1ub3QtY29weQ=="><div id="app"><div class="bg-gradient"></div><div class="grid-layer"></div><div class="motif-layer"><svg viewBox="0 0 400 400" fill="none" xmlns="http://www.w3.org/2000/svg"><g stroke="#eccb8d" stroke-width="1"><circle cx="200" cy="200" r="150"/><circle cx="200" cy="200" r="120"/><path d="M200 50 C 260 90, 260 150, 200 200 C 140 150, 140 90, 200 50 Z"/><path d="M200 350 C 260 310, 260 250, 200 200 C 140 250, 140 310, 200 350 Z"/><path d="M50 200 C 90 140, 150 140, 200 200 C 150 260, 90 260, 50 200 Z"/><path d="M350 200 C 310 140, 250 140, 200 200 C 250 260, 310 260, 350 200 Z"/><path d="M91 91 C 130 110, 130 150, 110 180 C 80 160, 70 120, 91 91 Z"/><path d="M309 91 C 270 110, 270 150, 290 180 C 320 160, 330 120, 309 91 Z"/><path d="M91 309 C 130 290, 130 250, 110 220 C 80 240, 70 280, 91 309 Z"/><path d="M309 309 C 270 290, 270 250, 290 220 C 320 240, 330 280, 309 309 Z"/></g></svg></div><canvas id="particleCanvas"></canvas><div id="petalLayer"></div><div id="heartLayer"></div><canvas id="fireworkCanvas"></canvas><div class="devtools-warning" id="devtoolsWarning"><div>This page is meant to be experienced, not inspected 💛<br>Please close developer tools to continue.</div></div><div class="splash-screen" id="splashScreen"><div class="balloon-field"><div class="balloon b1"></div><div class="balloon b2"></div><div class="balloon b3"></div><div class="balloon b4"></div><div class="balloon b5"></div><div class="balloon b6"></div></div><div class="splash-content"><div class="splash-title"><span class="word happy">Happy</span> <span class="word birthday">Birthday</span></div><div class="splash-name">Keerthy <span class="sparkle">✦</span></div><div class="splash-sub">A LITTLE JOURNEY, JUST FOR YOU</div><button class="btn-primary splash-btn" id="splashEnterBtn">Open your surprise</button></div></div><div class="gate-screen" id="countdownGate"><div class="card"><div class="gate-icon"><svg viewBox="0 0 34 34" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="17" cy="17" r="10.5" stroke="var(--gold-bright)" stroke-width="1"/><path d="M17 10.5V17L21.5 19.5" stroke="var(--gold-bright)" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/></svg></div><span class="eyebrow">Your surprise is waiting</span><h1>Something is counting down <span class="highlight">just for you</span></h1><div class="divider"></div><div class="countdown-grid"><div class="cd-tile"><span class="cd-num" id="cdDays">00</span><span class="cd-label">Days</span></div><div class="cd-sep">:</div><div class="cd-tile"><span class="cd-num" id="cdHours">00</span><span class="cd-label">Hours</span></div><div class="cd-sep">:</div><div class="cd-tile"><span class="cd-num" id="cdMins">00</span><span class="cd-label">Mins</span></div><div class="cd-sep">:</div><div class="cd-tile"><span class="cd-num" id="cdSecs">00</span><span class="cd-label">Secs</span></div></div><p class="sub" id="cdMessage">Come back on September 9th at midnight, Keeks. It'll be worth the wait 💛</p><div class="btn-row" id="cdBtnRow"><button class="btn-primary" id="cdContinueBtn">It's time ✦</button></div></div></div><button class="music-toggle" id="musicToggle" aria-label="Toggle background music" title="Toggle music"><svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" id="musicIconStatic"><path d="M9 18V5l12-2v13" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/><circle cx="6" cy="18" r="3" stroke="currentColor" stroke-width="1.4"/><circle cx="18" cy="16" r="3" stroke="currentColor" stroke-width="1.4"/></svg> <svg viewBox="0 0 24 24" id="musicIconPlaying" style="display:none;"><rect class="bar bar1" x="4" y="9" width="3" height="8" rx="1" fill="currentColor"/><rect class="bar bar2" x="10.5" y="5" width="3" height="14" rx="1" fill="currentColor"/><rect class="bar bar3" x="17" y="9" width="3" height="8" rx="1" fill="currentColor"/></svg></button><audio id="bgMusic" loop autoplay playsinline preload="metadata"><source src="./Sidu Sidu (3).mp3" type="audio/mpeg"></audio><div class="lyrics-overlay" id="lyricsOverlay"><p class="lyric-prev" id="lyricPrev"></p><p class="lyric-current" id="lyricCurrent"></p><p class="lyric-next" id="lyricNext"></p></div><div class="progress-wrap"><div class="thread"><div class="thread-fill" id="threadFill"></div></div><div class="progress" id="progressDots"><span class="active" data-i="0"></span> <span data-i="1"></span> <span data-i="2"></span> <span data-i="3"></span> <span data-i="4"></span> <span data-i="5"></span> <span data-i="6"></span> <span data-i="7"></span> <span data-i="8"></span></div></div><div class="screen" id="screen0"><div class="card"><div class="ornament"><svg viewBox="0 0 34 34" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="17" cy="17" r="10.5" stroke-width="1"/><line x1="17" y1="1" x2="17" y2="6" stroke-width="1"/><line x1="17" y1="28" x2="17" y2="33" stroke-width="1"/><line x1="1" y1="17" x2="6" y2="17" stroke-width="1"/><line x1="28" y1="17" x2="33" y2="17" stroke-width="1"/></svg></div><span class="eyebrow">A birthday note, for you alone</span><h1>Happy Birthday, <span class="highlight">Keerthy</span></h1><div class="divider"></div><p class="sub">Somewhere between an ordinary September and this one, you became the softest, brightest part of my life.<br>Today isn't just about the candles — it's about every quiet reason you're worth celebrating.<br>So before anything else, Keeks: I hope this whole year loves you as much as I do.</p><div class="btn-row"><button class="btn-primary" onclick="goTo(1)">Continue</button></div></div></div><div class="screen" id="screen1"><div class="card"><div class="ornament"><svg viewBox="0 0 34 34" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="17" cy="17" r="10.5" stroke-width="1"/><line x1="17" y1="1" x2="17" y2="6" stroke-width="1"/><line x1="17" y1="28" x2="17" y2="33" stroke-width="1"/><line x1="1" y1="17" x2="6" y2="17" stroke-width="1"/><line x1="28" y1="17" x2="33" y2="17" stroke-width="1"/></svg></div><span class="eyebrow">Together 1 of 6</span><h1>Do you know how <span class="highlight">special</span> you've always been to me?</h1><div class="divider"></div><p class="sub">On my heaviest days, your name crossing my mind was enough to make the weight feel smaller.<br>You've been my calm in the middle of everything, and I don't think I've ever said that out loud.</p><div class="btn-row"><button class="btn-primary" onclick="goTo(2)">I didn't know</button></div></div></div><div class="screen" id="screen2"><div class="card"><div class="ornament"><svg viewBox="0 0 34 34" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="17" cy="17" r="10.5" stroke-width="1"/><line x1="17" y1="1" x2="17" y2="6" stroke-width="1"/><line x1="17" y1="28" x2="17" y2="33" stroke-width="1"/><line x1="1" y1="17" x2="6" y2="17" stroke-width="1"/><line x1="28" y1="17" x2="33" y2="17" stroke-width="1"/></svg></div><span class="eyebrow">Together 2 of 6</span><h1>Have I ever made you <span class="highlight">smile</span> without you knowing it was me?</h1><div class="divider"></div><p class="sub">Every silly joke to fix a bad mood, every "did you eat yet," every message sent just to check on you —<br>none of it was random. It was me, quietly showing up for you in the only ways I knew how.</p><div class="btn-row"><button class="btn-primary" onclick="goTo(3)">Maybe you did</button></div></div></div><div class="screen" id="screen3"><div class="card"><div class="ornament"><svg viewBox="0 0 34 34" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="17" cy="17" r="10.5" stroke-width="1"/><line x1="17" y1="1" x2="17" y2="6" stroke-width="1"/><line x1="17" y1="28" x2="17" y2="33" stroke-width="1"/><line x1="1" y1="17" x2="6" y2="17" stroke-width="1"/><line x1="28" y1="17" x2="33" y2="17" stroke-width="1"/></svg></div><span class="eyebrow">Together 3 of 6</span><h1>Do you believe some feelings are worth <span class="highlight">waiting</span> for?</h1><div class="divider"></div><p class="sub">I've carried this quietly for longer than this September — through every conversation I almost turned into a confession.<br>Some things deserve patience. This is the one I finally stopped waiting on.</p><div class="btn-row"><button class="btn-primary" onclick="goTo(4)">Tell me everything</button></div></div></div><div class="screen" id="screen4"><div class="card"><div class="ornament"><svg viewBox="0 0 34 34" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="17" cy="17" r="10.5" stroke-width="1"/><line x1="17" y1="1" x2="17" y2="6" stroke-width="1"/><line x1="17" y1="28" x2="17" y2="33" stroke-width="1"/><line x1="1" y1="17" x2="6" y2="17" stroke-width="1"/><line x1="28" y1="17" x2="33" y2="17" stroke-width="1"/></svg></div><span class="eyebrow">Together 4 of 6</span><h1>Keeks, will you accept my <span class="highlight">love</span>?</h1><div class="divider"></div><p class="sub">I've kept this safe in my heart for so long, turning it over on nights I couldn't sleep.<br>No more keeping it to myself — here it is, exactly as honestly as I know how to say it.</p><div class="btn-row" id="row4"><button class="btn-primary" onclick="goTo(5)">Accept</button> <button class="btn-dodge" id="rejectBtn">Reject</button></div><p class="note">psst — that other button is a little shy</p></div></div><div class="screen" id="screen5"><div class="card"><div class="ornament"><svg viewBox="0 0 34 34" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="17" cy="17" r="10.5" stroke-width="1"/><line x1="17" y1="1" x2="17" y2="6" stroke-width="1"/><line x1="17" y1="28" x2="17" y2="33" stroke-width="1"/><line x1="1" y1="17" x2="6" y2="17" stroke-width="1"/><line x1="28" y1="17" x2="33" y2="17" stroke-width="1"/></svg></div><span class="eyebrow">Together 5 of 6</span><h1>Let's plan our <span class="highlight">first dates</span> together?</h1><div class="divider"></div><p class="sub">I already have something in mind for us —</p><div class="date-grid single"><div class="date-tile"><span class="icon">🛕</span><h3>Temple Date</h3><p>A quiet visit together, asking for a beginning as gentle as this one</p></div></div><div class="btn-row" id="row5"><button class="btn-primary" onclick="goTo(6)">Yes, let's go</button> <button class="btn-dodge" id="noBtn">No</button></div><p class="note">that "No" button is even shier than the last one</p></div></div><div class="screen" id="screen6"><div class="card"><div class="ornament"><svg viewBox="0 0 34 34" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="17" r="6" stroke-width="1"/><circle cx="22" cy="17" r="6" stroke-width="1"/></svg></div><span class="eyebrow">Together 6 of 6</span><h1>Keeks, <span class="script">enna kalyanam</span> pannikiruya?</h1><div class="divider"></div><p class="sub">Naan ketkura oru kelvi ithu thaan — my love, my best friend, my forever.<br>I don't just want the turf dates and the temple visits.<br>I want a whole lifetime of them, with you, by my side, as my wife.<br><br>So Keeks, <span class="highlight">will you marry me</span>?</p><div class="btn-row" id="row6"><button class="btn-primary" onclick="goTo(7)">Yes, I'll marry you</button> <button class="btn-dodge" id="marryNoBtn">No</button></div><p class="note">this button is the shiest one yet — it knows the answer already</p></div></div><div class="screen" id="screen7"><div class="card wide"><div class="ornament"><svg viewBox="0 0 34 34" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="17" cy="17" r="10.5" stroke-width="1"/><line x1="17" y1="1" x2="17" y2="6" stroke-width="1"/><line x1="17" y1="28" x2="17" y2="33" stroke-width="1"/><line x1="1" y1="17" x2="6" y2="17" stroke-width="1"/><line x1="28" y1="17" x2="33" y2="17" stroke-width="1"/></svg></div><span class="eyebrow">Before forever begins</span><h1>A few <span class="highlight">moments</span> I never want to forget</h1><div class="divider"></div><p class="sub memory-tagline">Every one of these is was my memory.</p><div class="memory-scroll"><div class="heart-mask-wrap"><div class="heart-grid"><figure class="heart-tile"><img src="./1776440756080.png" alt="A memory of us" loading="lazy"><figcaption>where it started</figcaption></figure><figure class="heart-tile"><img src="./1776440792262.png" alt="A memory of us" loading="lazy"><figcaption>that day we laughed too much</figcaption></figure><figure class="heart-tile"><img src="./Screenshot_20240117-225102.png" alt="A memory of us" loading="lazy"><figcaption>us, being us</figcaption></figure><figure class="heart-tile"><img src="./Screenshot_20240422-160927.png" alt="A memory of us" loading="lazy"><figcaption>us, being us</figcaption></figure><figure class="heart-tile"><img src="./1776993965997.png" alt="A memory of us" loading="lazy"><figcaption>one of my favorites</figcaption></figure><figure class="heart-tile"><img src="./Screenshot_20260608-104309.Instagram.png" alt="A memory of us" loading="lazy"><figcaption>just you and me</figcaption></figure><figure class="heart-tile"><img src="./Screenshot_20240505-220954.png" alt="A memory of us" loading="lazy"><figcaption>us, being us</figcaption></figure><figure class="heart-tile"><img src="./Screenshot_20250611-182002~2.png" alt="A memory of us" loading="lazy"><figcaption>a memory I replay often</figcaption></figure><figure class="heart-tile"><img src="./Screenshot_20260705-123802.Instagram.png" alt="A memory of us" loading="lazy"><figcaption>us, being us</figcaption></figure><figure class="heart-tile"><img src="./1781450854050.png" alt="A memory of us" loading="lazy"><figcaption>still makes me smile</figcaption></figure><figure class="heart-tile"><img src="./1779183389082.png" alt="A memory of us" loading="lazy"><figcaption>the beginning of everything</figcaption></figure><figure class="heart-tile"><img src="./Screenshot_20260705-123802.Instagram.png" alt="A memory of us" loading="lazy"><figcaption>us, being us</figcaption></figure><figure class="heart-tile"><img src="./Screenshot_20260703-194614.Instagram.png" alt="A memory of us" loading="lazy"><figcaption>that day we laughed too much</figcaption></figure><figure class="heart-tile"><img src="./Screenshot_20260703-194614.Instagram.png" alt="A memory of us" loading="lazy"><figcaption>that day we laughed too much</figcaption></figure><figure class="heart-tile"><img src="./1777201714374.png" alt="A memory of us" loading="lazy"><figcaption>that day we laughed too much</figcaption></figure><figure class="heart-tile"><img src="./1777201714374.png" alt="A memory of us" loading="lazy"><figcaption>that day we laughed too much</figcaption></figure></div></div></div><div class="btn-row"><button class="btn-primary" onclick="goTo(8)">Onward, to forever</button></div><p class="note">edit the captions in the code to make each one truly ours</p></div></div><div class="screen final" id="screen8"><div class="card"><div class="heart-burst">✦ ✦ ✦</div><h1>You just made my <span class="highlight">whole life</span></h1><div class="divider"></div><p class="sub">Happy Birthday, <span class="script">Keeks</span>.<br>Thank you for saying yes to my love, to our dates, and now — to forever.<br><br>Here's to turf dates, temple visits, and a whole lifetime of memories as husband and wife, my September queen. I love you.</p></div></div></div><script>const _0x39ac2e=_0x3b17;(function(_0xdee4b5,_0x2b7917){const _0x5b7d37=_0x3b17,_0x586a4c=_0xdee4b5();while(!![]){try{const _0x4226f7=parseInt(_0x5b7d37(0x3f3))/0x1+parseInt(_0x5b7d37(0x25b))/0x2*(-parseInt(_0x5b7d37(0x372))/0x3)+-parseInt(_0x5b7d37(0x320))/0x4*(parseInt(_0x5b7d37(0x28f))/0x5)+-parseInt(_0x5b7d37(0x2a6))/0x6*(parseInt(_0x5b7d37(0x3b0))/0x7)+parseInt(_0x5b7d37(0x31c))/0x8*(-parseInt(_0x5b7d37(0x32a))/0x9)+-parseInt(_0x5b7d37(0x219))/0xa+-parseInt(_0x5b7d37(0x409))/0xb*(-parseInt(_0x5b7d37(0x348))/0xc);if(_