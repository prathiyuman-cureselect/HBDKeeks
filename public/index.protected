<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover"><title>Happy Birthday, Keeks</title><link rel="preconnect" href="https://fonts.googleapis.com"><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin><link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,500;1,600&family=Inter:wght@400;500;600&family=Petit+Formal+Script&display=swap" rel="stylesheet"><style>:root{--ink:#130e1c;--surface:#1c1528;--surface-2:#251c35;--wine:#5c2a38;--gold:#c9a35f;--gold-bright:#eccb8d;--gold-dim:rgba(201,163,95,0.35);--gold-veil:rgba(201,163,95,0.09);--rose:#d9a0ae;--cream:#f6eee0;--cream-dim:#cdb9c6}*{box-sizing:border-box}body,html{margin:0;height:100%;overflow:hidden;font-family:Inter,sans-serif;background:var(--ink);-webkit-user-select:none;-moz-user-select:none;-ms-user-select:none;user-select:none;-webkit-touch-callout:none;-webkit-tap-highlight-color:transparent}#app{position:relative;width:100%;height:100vh;height:100dvh;overflow:hidden}.bg-gradient{position:absolute;inset:0;background:radial-gradient(circle at 18% 20%,rgba(201,163,95,.13),transparent 45%),radial-gradient(circle at 85% 15%,rgba(217,160,174,.11),transparent 50%),radial-gradient(circle at 50% 100%,rgba(92,42,56,.28),transparent 60%),linear-gradient(180deg,#17101f 0,#100b18 100%);background-size:200% 200%;animation:24s infinite glowDrift;z-index:0}@keyframes glowDrift{0%,100%{background-position:0 0,100% 0,50% 100%}50%{background-position:20% 20%,70% 30%,50% 80%}}.grid-layer{position:absolute;inset:0;z-index:0;background-image:linear-gradient(rgba(201,163,95,.045) 1px,transparent 1px),linear-gradient(90deg,rgba(201,163,95,.045) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(circle at 50% 35%,rgba(0,0,0,0.85),transparent 72%);-webkit-mask-image:radial-gradient(circle at 50% 35%,rgba(0,0,0,0.85),transparent 72%);opacity:.7}.motif-layer{position:absolute;inset:0;z-index:1;display:flex;align-items:center;justify-content:center;pointer-events:none}.motif-layer svg{width:min(92vw,780px);height:min(92vw,780px);opacity:.07;animation:90s linear infinite motifTurn}@keyframes motifTurn{from{transform:rotate(0)}to{transform:rotate(360deg)}}#particleCanvas{position:absolute;inset:0;z-index:1;pointer-events:none}#petalLayer{position:absolute;inset:0;z-index:2;pointer-events:none;overflow:hidden}.petal{position:absolute;top:-30px;opacity:0;animation:linear infinite petalFall;filter:drop-shadow(0 0 6px rgba(201,163,95,.25))}@keyframes petalFall{0%{transform:translateY(0) translateX(0) rotate(0);opacity:0}8%{opacity:.85}92%{opacity:.6}100%{transform:translateY(112vh) translateX(24px) rotate(200deg);opacity:0}}#heartLayer{position:absolute;inset:0;z-index:2;pointer-events:none;overflow:hidden}.heart-float{position:absolute;bottom:-40px;opacity:0;animation:linear forwards heartRise;filter:drop-shadow(0 0 6px rgba(217,160,174,.4))}@keyframes heartRise{0%{transform:translateY(0) translateX(0) scale(.7) rotate(0);opacity:0}12%{opacity:.9}85%{opacity:.7}100%{transform:translateY(-108vh) translateX(18px) scale(1.05) rotate(12deg);opacity:0}}.heart-burst-particle{position:fixed;z-index:400;pointer-events:none;animation:1.1s cubic-bezier(.22,.9,.4,1) forwards heartBurstMove}@keyframes heartBurstMove{0%{transform:translate(0,0) scale(.4);opacity:1}100%{transform:translate(var(--hx),var(--hy)) scale(1.1);opacity:0}}.progress-wrap{position:absolute;top:22px;left:50%;transform:translateX(-50%);z-index:50;display:flex;flex-direction:column;align-items:center;gap:8px}.thread{position:relative;width:220px;height:2px;background:rgba(244,236,221,.12);border-radius:2px;overflow:hidden}.thread-fill{position:absolute;inset:0 auto 0 0;width:0%;background:linear-gradient(90deg,var(--gold),var(--gold-bright));box-shadow:0 0 8px var(--gold-dim);transition:width .6s cubic-bezier(.65,0,.35,1)}.progress{display:flex;gap:10px}.progress span{width:6px;height:6px;border-radius:50%;background:rgba(244,236,221,.18);transition:.4s}.progress span.active{background:var(--gold-bright);box-shadow:0 0 10px var(--gold-dim);transform:scale(1.4)}.music-toggle{position:absolute;top:20px;right:20px;z-index:60;width:42px;height:42px;border-radius:50%;border:1px solid var(--gold-dim);background:rgba(244,236,221,.04);backdrop-filter:blur(10px);display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--gold-bright);transition:transform .2s,border-color .2s,background .2s}.music-toggle:hover{transform:scale(1.08);border-color:var(--gold);background:rgba(244,236,221,.08)}.music-toggle svg{width:18px;height:18px}.music-toggle .bar{transform-origin:bottom;animation:none}.music-toggle.playing .bar1{animation:.9s ease-in-out infinite eqBar}.music-toggle.playing .bar2{animation:.9s ease-in-out .15s infinite eqBar}.music-toggle.playing .bar3{animation:.9s ease-in-out .3s infinite eqBar}@keyframes eqBar{0%,100%{transform:scaleY(.4)}50%{transform:scaleY(1)}}.screen{position:absolute;inset:0;display:none;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:24px;z-index:10}.screen.active{display:flex;animation:.95s cubic-bezier(.19,1,.22,1) screenIn}@keyframes screenIn{from{opacity:0;transform:translateY(22px) scale(.97);filter:blur(6px)}to{opacity:1;transform:translateY(0) scale(1);filter:blur(0)}}.screen.leaving{animation:.4s forwards screenOut}@keyframes screenOut{from{opacity:1;transform:scale(1)}to{opacity:0;transform:scale(.97)}}.card{background:linear-gradient(165deg,rgba(244,236,221,.055),rgba(244,236,221,.015));border:1px solid var(--gold-dim);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);border-radius:6px;padding:clamp(34px,5.5vw,56px) clamp(24px,5vw,52px);max-width:600px;width:100%;box-shadow:0 30px 80px rgba(0,0,0,.55);position:relative;transform-style:preserve-3d;will-change:transform;transition:transform .25s}.card.wide{max-width:760px}.card::after,.card::before{content:'';position:absolute;width:22px;height:22px;border:1px solid var(--gold);opacity:.8}.card::before{top:10px;left:10px;border-right:none;border-bottom:none}.card::after{bottom:10px;right:10px;border-left:none;border-top:none}.ornament{width:34px;height:34px;margin:0 auto 18px;opacity:.9;animation:3.6s ease-in-out infinite breathe}@keyframes breathe{0%,100%{opacity:.75;transform:scale(1)}50%{opacity:1;transform:scale(1.08)}}.ornament svg{width:100%;height:100%}.ornament circle,.ornament line,.ornament path{stroke:var(--gold-bright)}.eyebrow{display:block;font-family:Inter,sans-serif;font-size:11px;letter-spacing:3.5px;text-transform:uppercase;color:var(--gold-bright);opacity:.85;margin-bottom:14px;font-weight:500}h1{font-family:'Cormorant Garamond',serif;font-size:clamp(26px,5.4vw,42px);color:var(--cream);margin:6px 0 8px;letter-spacing:.2px;font-weight:600;line-height:1.28;opacity:0;animation:.9s .15s forwards riseIn}.highlight{color:var(--gold-bright);font-style:italic}.script{font-family:'Petit Formal Script',cursive;color:var(--gold-bright);font-size:1.5em}p.sub{color:var(--cream-dim);font-size:clamp(14.5px,2.2vw,16.5px);line-height:1.8;margin:14px 0 30px;opacity:0;animation:.9s .4s forwards riseIn;font-weight:400}@keyframes riseIn{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}.divider{width:56px;height:1px;background:linear-gradient(90deg,transparent,var(--gold),transparent);margin:2px auto 22px;opacity:.8}.date-grid{display:grid;grid-template-columns:1fr 1fr;gap:clamp(14px,3vw,20px);margin:4px 0 30px}.date-grid.single{grid-template-columns:1fr;max-width:280px;margin-left:auto;margin-right:auto}.date-tile{background:rgba(244,236,221,.03);border:1px solid var(--gold-dim);border-radius:4px;padding:clamp(18px,3.4vw,24px) clamp(12px,2.6vw,18px);opacity:0;animation:.9s .55s forwards riseIn;transition:transform .25s,border-color .25s,background .25s,box-shadow .25s}.date-tile:hover{transform:translateY(-4px);border-color:var(--gold);background:rgba(244,236,221,.05);box-shadow:0 14px 30px rgba(201,163,95,.18)}.date-tile .icon{font-size:clamp(24px,5vw,30px);display:block;margin-bottom:10px;opacity:.9}.date-tile h3{font-family:'Cormorant Garamond',serif;font-size:clamp(15px,2.6vw,18px);color:var(--cream);margin:2px 0 8px;font-weight:600;letter-spacing:.3px}.date-tile p{font-size:clamp(11.5px,2.1vw,12.5px);color:var(--cream-dim);margin:0;line-height:1.55}.memory-scroll{max-height:min(62vh,560px);overflow-y:auto;overflow-x:hidden;padding:6px 4px 10px;margin:6px 0 24px;scrollbar-width:thin;scrollbar-color:var(--gold-dim) transparent}.memory-scroll::-webkit-scrollbar{width:5px}.memory-scroll::-webkit-scrollbar-thumb{background:var(--gold-dim);border-radius:4px}.heart-mask-wrap{position:relative;width:min(86vw,460px);aspect-ratio:32/29;margin:6px auto 18px;-webkit-mask-image:url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 29'><path d='M16 29 C16 29 0 17.5 0 9 C0 4 4 0 8.7 0 C12.2 0 15.1 2.6 16 6.2 C16.9 2.6 19.8 0 23.3 0 C28 0 32 4 32 9 C32 17.5 16 29 16 29 Z'/></svg>");mask-image:url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 29'><path d='M16 29 C16 29 0 17.5 0 9 C0 4 4 0 8.7 0 C12.2 0 15.1 2.6 16 6.2 C16.9 2.6 19.8 0 23.3 0 C28 0 32 4 32 9 C32 17.5 16 29 16 29 Z'/></svg>");-webkit-mask-size:contain;mask-size:contain;-webkit-mask-repeat:no-repeat;mask-repeat:no-repeat;-webkit-mask-position:center;mask-position:center;filter:drop-shadow(0 18px 40px rgba(0,0,0,.5))}.heart-grid{display:grid;grid-template-columns:repeat(4,1fr);grid-template-rows:repeat(4,1fr);width:100%;height:100%;gap:2px;background:var(--ink)}.heart-tile{position:relative;margin:0;overflow:hidden;background:var(--surface-2);opacity:0;animation:.7s forwards tileIn;animation-delay:var(--d, 0s)}@keyframes tileIn{from{opacity:0;transform:scale(1.15)}to{opacity:1;transform:scale(1)}}.heart-tile:first-child{--d:0.05s}.heart-tile:nth-child(2){--d:0.12s}.heart-tile:nth-child(3){--d:0.19s}.heart-tile:nth-child(4){--d:0.26s}.heart-tile:nth-child(5){--d:0.33s}.heart-tile:nth-child(6){--d:0.40s}.heart-tile:nth-child(7){--d:0.47s}.heart-tile:nth-child(8){--d:0.54s}.heart-tile img{display:block;width:100%;height:100%;object-fit:cover;filter:sepia(.12) saturate(1.05);transition:transform .4s,filter .4s}.heart-tile:hover img{transform:scale(1.12);filter:sepia(0) saturate(1.15)}.heart-tile figcaption{position:absolute;inset:auto 0 0 0;padding:10px 6px 8px;background:linear-gradient(0deg,rgba(19,14,28,.88),transparent);font-family:'Petit Formal Script',cursive;font-size:12.5px;color:var(--cream);text-align:center;line-height:1.15;opacity:0;transform:translateY(6px);transition:opacity .3s,transform .3s}.heart-tile:hover figcaption{opacity:1;transform:translateY(0)}.memory-tagline{margin-top:-6px}.lyrics-overlay{position:absolute;left:50%;bottom:22px;transform:translateX(-50%);z-index:55;width:min(90vw,520px);text-align:center;pointer-events:none;opacity:0;transition:opacity .5s}.lyrics-overlay.visible{opacity:1}.lyrics-overlay .lyric-next,.lyrics-overlay .lyric-prev{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:clamp(11px,1.8vw,13px);color:var(--cream-dim);opacity:.4;margin:0;line-height:1.3}.lyrics-overlay .lyric-current{font-family:'Petit Formal Script',cursive;font-size:clamp(17px,3.4vw,23px);color:var(--gold-bright);margin:4px 0;line-height:1.3;text-shadow:0 0 16px rgba(201,163,95,.35);transition:opacity .35s,transform .35s;min-height:1.3em;display:inline-block}.lyrics-overlay .lyric-current.swap{opacity:0;transform:translateY(6px)}.btn-row{position:relative;display:flex;gap:clamp(14px,4vw,26px);justify-content:center;margin-top:6px;flex-wrap:wrap;min-height:60px}button{border:none;cursor:pointer;font-family:Inter,sans-serif;font-size:clamp(13.5px,2.3vw,15px);font-weight:600;letter-spacing:.4px;padding:clamp(13px,2.6vw,16px) clamp(28px,5vw,42px);border-radius:2px;transition:transform .15s,box-shadow .15s,left .22s,top .22s,background .2s;white-space:nowrap}.btn-primary{background:linear-gradient(135deg,var(--gold-bright),var(--gold));color:#211a2d;box-shadow:0 10px 24px rgba(201,163,95,.25)}.btn-primary:hover{transform:translateY(-2px);box-shadow:0 14px 30px rgba(201,163,95,.35)}.btn-primary:active{transform:translateY(0)}.btn-dodge{background:0 0;color:var(--cream-dim);border:1px solid var(--gold-dim)}.roaming{position:absolute!important;z-index:999;margin:0!important;animation:.5s wiggle}@keyframes wiggle{0%,100%{transform:rotate(0)}25%{transform:rotate(-4deg)}75%{transform:rotate(4deg)}}.note{margin-top:22px;font-size:clamp(11px,2vw,12.5px);color:var(--cream-dim);opacity:.6;font-style:italic;font-family:'Cormorant Garamond',serif}.heart-burst{font-size:clamp(20px,4vw,26px);letter-spacing:10px;color:var(--gold-bright);margin-bottom:6px;animation:1.8s ease-in-out infinite burstPulse}@keyframes burstPulse{0%,100%{opacity:.75;letter-spacing:10px}50%{opacity:1;letter-spacing:14px}}#fireworkCanvas{position:absolute;inset:0;z-index:11;pointer-events:none}@media (prefers-reduced-motion:reduce){*{animation-duration:0s!important;animation-iteration-count:1!important}.card{transition:none!important;transform:none!important}}@media (max-width:375px){.card{padding:26px 18px}.btn-row{gap:12px}button{padding:12px 22px;font-size:13px}.progress-wrap{top:14px}.thread{width:150px}.date-grid{grid-template-columns:1fr;gap:10px}.music-toggle{top:14px;right:14px;width:36px;height:36px}.heart-mask-wrap{width:82vw}}@media (min-width:376px) and (max-width:480px){.card{padding:28px 22px}.date-grid{grid-template-columns:1fr;gap:12px}}@media (min-width:601px) and (max-width:900px){.card{max-width:560px;padding:40px 38px}.card.wide{max-width:640px}}@media (min-width:901px){.card{max-width:600px;padding:50px 46px}.card.wide{max-width:760px}}@media (max-height:480px){.lyrics-overlay{bottom:10px}.lyrics-overlay .lyric-next,.lyrics-overlay .lyric-prev{display:none}.card{padding:1